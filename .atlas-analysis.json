  "keyFeatures": [
    "Type-safe command DSL builders",
    "Reified generic event registration",
    "Component codec DSL for ECS serialization",
    "Coroutine support with Hytale dispatchers",
    "ItemStack builder with metadata support",
    "Interaction DSL for entity interactions",
    "UI page extensions"
  ],
